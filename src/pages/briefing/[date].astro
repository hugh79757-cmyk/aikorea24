---
export const prerender = false;
const { date } = Astro.params;
let debugMsg = "OK";
let runtime_type = "unknown";
let db_type = "unknown";
try {
  const runtime = (Astro.locals as any).runtime;
  runtime_type = typeof runtime;
  const db = runtime?.env?.DB;
  db_type = typeof db;
  if (db) {
    const result = await db.prepare("SELECT COUNT(*) as cnt FROM briefings").first();
    debugMsg = "DB query OK, count=" + JSON.stringify(result);
  } else {
    debugMsg = "DB is null/undefined";
  }
} catch(e: any) {
  debugMsg = "ERROR: " + e.message;
}
---
<html lang="ko">
<head><meta charset="UTF-8"><title>Debug</title></head>
<body>
<h1>Briefing Debug</h1>
<p>Date: {date}</p>
<p>Runtime: {runtime_type}</p>
<p>DB: {db_type}</p>
<p>Result: {debugMsg}</p>
</body>
</html>
