---
export const prerender = false;

const ADMIN_EMAILS = ['twinssn@gmail.com'];

let isAuth = false;
const session = Astro.cookies.get('session')?.value;
if (session) {
  try {
    const user = JSON.parse(atob(session));
    isAuth = ADMIN_EMAILS.includes(user.email);
  } catch {}
}

if (!isAuth) {
  return new Response('Unauthorized', { status: 401 });
}
---
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" href="/favicon.png" />
<title>이벤트 권한 관리 - 관리자</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0f172a;color:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;padding:20px}
h1{font-size:1.4rem;margin-bottom:16px}
.nav{margin-bottom:20px;display:flex;gap:8px}
.nav a{color:#94a3b8;text-decoration:none;padding:6px 14px;border-radius:6px;font-size:.85rem;background:#1e293b;border:1px solid #334155}
.nav a:hover,.nav a.on{background:#3b82f6;color:#fff;border-color:#3b82f6}
.section{background:#1e293b;border:1px solid #334155;border-radius:10px;padding:20px;margin-bottom:20px}
.section h2{font-size:1.1rem;margin-bottom:12px;color:#93c5fd}
label{display:block;font-size:.85rem;color:#94a3b8;margin-bottom:4px}
input,select{width:100%;background:#0f172a;color:#e2e8f0;border:1px solid #475569;border-radius:6px;padding:8px 12px;font-size:.9rem;margin-bottom:12px}
input:focus,select:focus{outline:none;border-color:#3b82f6}
.btn{background:#2563eb;color:#fff;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;font-size:.85rem;font-weight:600}
.btn:hover{background:#3b82f6}
.btn.red{background:#dc2626}
.btn.red:hover{background:#ef4444}
.btn:disabled{background:#334155;color:#64748b;cursor:not-allowed}
.msg{font-size:.85rem;margin:8px 0}
.msg.ok{color:#4ade80}
.msg.err{color:#f87171}
table{width:100%;border-collapse:collapse;font-size:.85rem;margin-top:12px}
th{text-align:left;color:#64748b;padding:8px 6px;border-bottom:1px solid #334155;font-weight:500}
td{padding:8px 6px;border-bottom:1px solid #1e293b;color:#cbd5e1}
td.email{color:#93c5fd;font-weight:500}
td.dl{color:#4ade80}
td.nodl{color:#64748b}
.del-btn{background:none;border:1px solid #64748b;color:#f87171;padding:3px 10px;border-radius:4px;cursor:pointer;font-size:.75rem}
.del-btn:hover{background:#dc2626;color:#fff;border-color:#dc2626}
.stats{display:flex;gap:16px;margin-bottom:16px}
.stat-box{background:#0f172a;border:1px solid #334155;border-radius:8px;padding:12px 16px;flex:1;text-align:center}
.stat-num{font-size:1.4rem;font-weight:700;color:#3b82f6}
.stat-label{font-size:.75rem;color:#64748b;margin-top:2px}
</style>
<meta name="google-site-verification" content="kpr0gRmGKIFUW5dNLsfxba1aKpbV7wolSFk6cSOJZXA" />
<meta name="naver-site-verification" content="fa2baf09d65dfb84a55787b8740941430187b234" />
<style>
.skiptranslate{display:none!important}body{top:0!important}
</style>
</head>
<body>
<div class="translate-flags" style="position:fixed;top:8px;right:8px;z-index:9999;display:flex;gap:6px;padding:6px 10px;background:rgba(10,10,15,0.85);backdrop-filter:blur(8px);border-radius:8px;">
  <a href="javascript:void(0)" onclick="doTranslate('ko')" title="한국어" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/kr.png" alt="한국어" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('en')" title="English" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/us.png" alt="English" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('zh-CN')" title="中文" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/cn.png" alt="中文" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('ja')" title="日本語" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/jp.png" alt="日本語" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('vi')" title="Tiếng Việt" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/vn.png" alt="Tiếng Việt" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('th')" title="ภาษาไทย" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/th.png" alt="ภาษาไทย" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('es')" title="Español" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/es.png" alt="Español" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('fr')" title="Français" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;"><img src="https://flagcdn.com/w80/fr.png" alt="Français" style="width:100%;height:100%;object-fit:cover;"></a>
</div>



<h1>이벤트 권한 관리</h1>
<div class="nav">
  <a href="/admin/">브리핑</a>
  <a href="/admin/event/" class="on">이벤트</a>
</div>

<!-- 통계 -->
<div class="stats" id="stats">
  <div class="stat-box"><div class="stat-num" id="s-total">-</div><div class="stat-label">총 권한</div></div>
  <div class="stat-box"><div class="stat-num" id="s-downloaded">-</div><div class="stat-label">다운로드 완료</div></div>
  <div class="stat-box"><div class="stat-num" id="s-pending">-</div><div class="stat-label">미다운로드</div></div>
</div>

<!-- 권한 부여 -->
<div class="section">
  <h2>권한 부여</h2>
  <label>이메일 (Google 계정)</label>
  <input type="email" id="grantEmail" placeholder="user@gmail.com" />
  <label>리소스</label>
  <select id="grantResource"><option value="">로딩 중...</option></select>
  <div style="display:flex;gap:8px;align-items:center;">
    <button class="btn" id="grantBtn">권한 부여</button>
    <span class="msg" id="grantMsg"></span>
  </div>
</div>

<!-- 권한 목록 -->
<div class="section">
  <h2>권한 목록</h2>
  <table>
    <thead><tr><th>이메일</th><th>리소스</th><th>부여일</th><th>다운로드</th><th></th></tr></thead>
    <tbody id="grantList"></tbody>
  </table>
</div>



<script is:inline>
function doTranslate(lang) {
  if (lang === 'ko') {
    if (window.location.hostname.includes('translate.goog')) {
      var orig = window.location.href.replace(/^https?:\/\/[^/]*translate\.goog/, 'https://aikorea24.kr');
      orig = orig.replace(/[?&]_x_tr_[^&]*/g, '');
      window.location.href = orig || 'https://aikorea24.kr';
    }
    return;
  }
  var url = 'https://translate.google.com/translate?sl=ko&tl=' + lang + '&u=' + encodeURIComponent(window.location.href);
  window.location.href = url;
}
</script>
</body>
</html>
