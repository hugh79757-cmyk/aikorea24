---
const url = new URL(Astro.request.url);
const code = url.searchParams.get('code') || '';
const message = url.searchParams.get('message') || '결제가 취소되었습니다.';
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" href="/favicon.png" />
  <title>결제 실패 - aikorea24.kr</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
  <style>
    body { background: #0f172a; color: #e2e8f0; font-family: 'Pretendard', -apple-system, sans-serif; }
    .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(148, 163, 184, 0.1); }
  </style>
<meta name="google-site-verification" content="kpr0gRmGKIFUW5dNLsfxba1aKpbV7wolSFk6cSOJZXA" />
<meta name="naver-site-verification" content="fa2baf09d65dfb84a55787b8740941430187b234" />
<style>
.skiptranslate{display:none!important}body{top:0!important}
</style>
</head>
<body class="min-h-screen flex items-center justify-center">
<div class="translate-flags" style="display:flex;justify-content:center;gap:8px;padding:6px 0;background:transparent;position:fixed;top:8px;right:8px;z-index:9999;">
  <a href="javascript:void(0)" onclick="doTranslate('ko')" class="flag-btn" title="한국어" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/kr.png" alt="한국어" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('en')" class="flag-btn" title="English" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/us.png" alt="English" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('zh-CN')" class="flag-btn" title="中文" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/cn.png" alt="中文" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('ja')" class="flag-btn" title="日本語" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/jp.png" alt="日本語" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('vi')" class="flag-btn" title="Tiếng Việt" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/vn.png" alt="Tiếng Việt" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('th')" class="flag-btn" title="ภาษาไทย" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/th.png" alt="ภาษาไทย" style="width:100%;height:100%;object-fit:cover;"></a>
</div>
<div id="google_translate_element" style="display:none;"></div>
  <div class="glass rounded-2xl p-10 text-center max-w-md">
    <div class="text-5xl mb-4">😔</div>
    <h1 class="text-2xl font-bold text-yellow-400 mb-4">결제 실패</h1>
    <p class="text-gray-400 mb-2">{message}</p>
    {code && <p class="text-gray-500 text-sm mb-6">오류 코드: {code}</p>}
    <a href="/community" class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg font-medium transition">
      돌아가기
    </a>
  </div>
<script is:inline>
function googleTranslateElementInit(){
  new google.translate.TranslateElement({pageLanguage:'ko',autoDisplay:false},'google_translate_element');
}
function doTranslate(lang){
  var s=document.querySelector('.goog-te-combo');
  if(s){s.value=lang;s.dispatchEvent(new Event('change'));return;}
  var i=setInterval(function(){
    var s2=document.querySelector('.goog-te-combo');
    if(s2){clearInterval(i);s2.value=lang;s2.dispatchEvent(new Event('change'));}
  },500);
  setTimeout(function(){clearInterval(i);},10000);
}
</script>
<script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
