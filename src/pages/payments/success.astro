  </div>


<script is:inline>
function doTranslate(lang) {
  if (lang === 'ko') {
    if (window.location.hostname.includes('translate.goog')) {
      var orig = window.location.href.replace(/^https?:\/\/[^/]*translate\.goog/, 'https://aikorea24.kr');
      orig = orig.replace(/[?&]_x_tr_[^&]*/g, '');
      window.location.href = orig || 'https://aikorea24.kr';
    }
    return;
  }
  var url = 'https://translate.google.com/translate?sl=ko&tl=' + lang + '&u=' + encodeURIComponent(window.location.href);
  window.location.href = url;
}
</script>
