---
import Layout from '../../layouts/Layout.astro';

let currentUser = null;
try {
  const session = Astro.cookies.get('session')?.value;
  if (session) currentUser = JSON.parse(atob(session));
} catch {}
---
<Layout title="이벤트 - 2월 추천글감 키워드 무료 제공" description="뉴스 키워드 인사이트 Pro 피드백 이벤트. 2월 추천글감 엑기스 키워드를 무료로 받아가세요.">
  <div class="bg-[var(--bg-primary)] min-h-screen">
    <div class="max-w-3xl mx-auto px-4 py-16">

      <!-- 히어로 -->
      <div class="text-center mb-12">
        <span class="inline-block bg-blue-500/20 text-blue-400 text-sm font-medium px-4 py-1.5 rounded-full mb-4">EVENT</span>
        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-4">
          2월 추천글감 키워드<br/>무료로 드립니다
        </h1>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed">
          <a href="https://keyword.aikorea24.kr" target="_blank" class="text-blue-400 hover:text-blue-300 underline">뉴스 키워드 인사이트 Pro</a>에서
          2월 한 달간 분석한 추천글감의 엑기스 키워드를 CSV로 정리했습니다.
        </p>
      </div>

      <!-- 참여 방법 -->
      <div class="bg-[var(--card-bg)] border border-[var(--card-border)] rounded-2xl p-8 mb-8">
        <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">참여 방법</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-blue-500/20 text-blue-400 rounded-full flex items-center justify-center font-bold text-sm">1</div>
            <div>
              <h3 class="font-semibold text-[var(--text-primary)] mb-1">피드백 보내기</h3>
              <p class="text-[var(--text-secondary)] text-sm leading-relaxed">
                <a href="https://keyword.aikorea24.kr" target="_blank" class="text-blue-400 hover:text-blue-300 underline">뉴스 키워드 인사이트 Pro</a>를
                사용해보시고, <a href="https://www.threads.net/@aikorea24" target="_blank" class="text-blue-400 hover:text-blue-300 underline">Threads @aikorea24</a> 게시물에 댓글로 좋았던 점 / 아쉬운 점 / 개선 아이디어를 자유롭게 알려주세요.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-blue-500/20 text-blue-400 rounded-full flex items-center justify-center font-bold text-sm">2</div>
            <div>
              <h3 class="font-semibold text-[var(--text-primary)] mb-1">Google 이메일 알려주기</h3>
              <p class="text-[var(--text-secondary)] text-sm leading-relaxed">
                피드백과 함께 Google 계정 이메일을 보내주세요. 다운로드 권한을 드립니다.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-blue-500/20 text-blue-400 rounded-full flex items-center justify-center font-bold text-sm">3</div>
            <div>
              <h3 class="font-semibold text-[var(--text-primary)] mb-1">키워드 다운로드</h3>
              <p class="text-[var(--text-secondary)] text-sm leading-relaxed">
                권한이 부여되면 <a href="/event/download/" class="text-blue-400 hover:text-blue-300 underline">다운로드 페이지</a>에서
                Google 로그인 후 CSV 파일을 받을 수 있습니다.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 피드백 채널 안내 -->
      <div class="bg-[var(--card-bg)] border border-[var(--card-border)] rounded-2xl p-8 mb-8">
        <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">피드백은 어디로?</h2>
        <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-4">
          아래 어느 채널이든 편한 곳으로 보내주세요.
        </p>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="text-lg">🧵</span>
            <span class="text-[var(--text-secondary)] text-sm">Threads — <a href="https://www.threads.net/@aikorea24" target="_blank" class="text-blue-400 hover:text-blue-300 underline">@aikorea24</a> 게시물에 댓글로 피드백</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg">📧</span>
            <span class="text-[var(--text-secondary)] text-sm">이메일 — <a href="mailto:info@aikorea24.kr" class="text-blue-400 hover:text-blue-300 underline">info@aikorea24.kr</a></span>
          </div>
        </div>
      </div>

      <!-- 키워드 미리보기 -->
      <div class="bg-[var(--card-bg)] border border-[var(--card-border)] rounded-2xl p-8 mb-8">
        <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">어떤 키워드인가요?</h2>
        <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-4">
          2월 한 달간 뉴스 키워드 인사이트 Pro에서 분석한 트렌드 키워드 중,
          블로그 글감으로 활용하기 좋은 키워드만 엄선했습니다.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-blue-500/10 text-blue-400 text-xs px-3 py-1 rounded-full">검색량 데이터 포함</span>
          <span class="bg-green-500/10 text-green-400 text-xs px-3 py-1 rounded-full">경쟁도 분석</span>
          <span class="bg-purple-500/10 text-purple-400 text-xs px-3 py-1 rounded-full">추천 글감 방향</span>
          <span class="bg-yellow-500/10 text-yellow-400 text-xs px-3 py-1 rounded-full">CSV 포맷</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        {currentUser ? (
          <a href="/event/download/" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3 rounded-xl transition-colors">
            다운로드 페이지로 이동
          </a>
        ) : (
          <a href="/api/auth/login/" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3 rounded-xl transition-colors">
            Google 로그인하고 참여하기
          </a>
        )}
      </div>

    </div>
  </div>
</Layout>
