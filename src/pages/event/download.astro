---
import Layout from '../../layouts/Layout.astro';

let currentUser = null;
try {
  const session = Astro.cookies.get('session')?.value;
  if (session) currentUser = JSON.parse(atob(session));
} catch {}

if (!currentUser) {
  return Astro.redirect('/api/auth/login/');
}
---
<Layout title="이벤트 다운로드 - aikorea24.kr" description="피드백 이벤트 참여자 전용 다운로드 페이지">
  <div class="bg-[var(--bg-primary)] min-h-screen">
    <div class="max-w-3xl mx-auto px-4 py-16">

      <div class="text-center mb-10">
        <h1 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-2">이벤트 다운로드</h1>
        <p class="text-[var(--text-secondary)] text-sm">
          <span class="text-blue-400">{currentUser.name || currentUser.email}</span>님, 환영합니다!
        </p>
      </div>

      <div id="loading" class="text-center py-12">
        <div class="inline-block w-8 h-8 border-2 border-blue-400 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-[var(--text-muted)] text-sm mt-3">권한 확인 중...</p>
      </div>

      <div id="resources" class="hidden space-y-4"></div>

      <div id="no-access" class="hidden">
        <div class="bg-[var(--card-bg)] border border-[var(--card-border)] rounded-2xl p-8 text-center">
          <div class="text-4xl mb-4">🔒</div>
          <h2 class="text-lg font-bold text-[var(--text-primary)] mb-2">아직 다운로드 권한이 없습니다</h2>
          <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-6">
            피드백을 보내주시면 다운로드 권한을 드립니다.<br/>
            이미 보내셨다면 권한 부여까지 잠시만 기다려주세요.
          </p>
          <a href="/event/" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
            이벤트 안내 보기
          </a>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
    async function loadResources() {
      try {
        const res = await fetch('/api/resources/');
        if (!res.ok) {
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('no-access').classList.remove('hidden');
          return;
        }
        const data = await res.json();
        const list = data.resources || [];

        document.getElementById('loading').classList.add('hidden');

        if (list.length === 0) {
          document.getElementById('no-access').classList.remove('hidden');
          return;
        }

        const container = document.getElementById('resources');
        container.classList.remove('hidden');

        list.forEach(function(r) {
          var downloaded = r.downloaded_at
            ? '<span style="color:#4ade80;font-size:0.75rem;">✓ ' + r.downloaded_at.slice(0, 16) + ' 다운로드됨</span>'
            : '';

          container.innerHTML += '<div class="bg-[var(--card-bg)] border border-[var(--card-border)] rounded-2xl p-6">'
            + '<div class="flex items-start justify-between gap-4">'
            + '<div>'
            + '<h3 class="font-bold text-[var(--text-primary)] mb-1">' + r.title + '</h3>'
            + '<p class="text-[var(--text-secondary)] text-sm mb-2">' + (r.description || '') + '</p>'
            + '<div class="flex items-center gap-3">'
            + '<span class="text-xs text-[var(--text-muted)]">📄 ' + r.filename + '</span>'
            + downloaded
            + '</div>'
            + '</div>'
            + '<a href="/api/resources/download/?id=' + r.id + '" class="flex-shrink-0 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">'
            + '다운로드'
            + '</a>'
            + '</div>'
            + '</div>';
        });
      } catch (e) {
        document.getElementById('loading').classList.add('hidden');
        document.getElementById('no-access').classList.remove('hidden');
      }
    }
    loadResources();
  </script>
</Layout>
