---
const session = Astro.cookies.get('session')?.value;
let user: any = null;
if (session) {
  try {
    user = JSON.parse(atob(session.split('.')[1] || session));
  } catch {}
}

if (!user) {
  return Astro.redirect('/auth/consent');
}

const categoryMap: Record<string, string> = {
  free: '자유게시판',
  qna: '질문답변',
  news: 'AI 뉴스',
  tip: '꿀팁공유',
  project: '프로젝트',
};
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" href="/favicon.png" />
  <title>글쓰기 - 커뮤니티 - aikorea24.kr</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
  <style>
    body { background: #0f172a; color: #e2e8f0; font-family: 'Pretendard', -apple-system, sans-serif; }
    .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(148, 163, 184, 0.1); }
    textarea, input, select {
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid rgba(148, 163, 184, 0.2);
      color: #e2e8f0;
    }
    textarea:focus, input:focus, select:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3);
    }
  </style>
<meta name="google-site-verification" content="kpr0gRmGKIFUW5dNLsfxba1aKpbV7wolSFk6cSOJZXA" />
<meta name="naver-site-verification" content="fa2baf09d65dfb84a55787b8740941430187b234" />
<style>
.skiptranslate{display:none!important}body{top:0!important}
.flag-bar{position:fixed;top:0;right:0;z-index:9999;display:flex;gap:4px;padding:6px 10px;background:rgba(10,10,15,0.85);backdrop-filter:blur(8px);border-radius:0 0 0 10px}
.flag-bar a{display:block;width:24px;height:18px;border-radius:3px;overflow:hidden;opacity:0.7;transition:opacity .2s}
.flag-bar a:hover{opacity:1}
.flag-bar a img{width:100%;height:100%;object-fit:cover}
</style>
</head>
<body class="min-h-screen">

  <header class="glass sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-white">🤖 aikorea24</a>
      <nav class="flex items-center gap-4 text-sm">
        <a href="/community" class="text-gray-600 dark:text-gray-300 hover:text-white">← 목록으로</a>
      </nav>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-8">

    <h1 class="text-2xl font-bold text-white mb-8">글쓰기</h1>

    <div id="error-msg" class="hidden bg-red-500/20 border border-red-500/50 text-red-300 px-4 py-3 rounded-lg mb-6"></div>

    <form id="write-form" class="space-y-6">

      <div class="flex gap-4">
        <div class="flex-shrink-0">
          <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">카테고리</label>
          <select id="category" class="rounded-lg px-4 py-3 w-40">
            {Object.entries(categoryMap).map(([key, label]) => (
              <option value={key}>{label}</option>
            ))}
          </select>
        </div>
        <div class="flex-1">
          <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">제목</label>
          <input type="text" id="title" maxlength="200" placeholder="제목을 입력하세요"
                 class="rounded-lg px-4 py-3 w-full" required />
        </div>
      </div>

      <div class="flex gap-4">
        <div>
          <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">공개 범위</label>
          <select id="access_level" class="rounded-lg px-4 py-3 w-40">
            <option value="free">무료 (전체공개)</option>
            <option value="basic">Basic (구독자)</option>
            <option value="premium">Premium (프리미엄)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">건별 가격 (원)</label>
          <input type="number" id="price" min="0" step="100" value="0" placeholder="0이면 건별구매 불가"
                 class="rounded-lg px-4 py-3 w-40" />
        </div>
      </div>

      <div id="preview-section" class="hidden">
        <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">미리보기 내용 (비회원에게 보이는 부분)</label>
        <textarea id="preview_content" rows="4" maxlength="500" placeholder="유료 글의 맛보기 내용을 입력하세요"
                  class="rounded-lg px-4 py-3 w-full resize-y"></textarea>
      </div>

      <div>
        <label class="block text-sm text-gray-500 dark:text-gray-400 mb-2">내용</label>
        <textarea id="content" rows="15" maxlength="10000" placeholder="내용을 입력하세요"
                  class="rounded-lg px-4 py-3 w-full resize-y" required></textarea>
        <div class="text-right text-xs text-gray-500 mt-1">
          <span id="char-count">0</span> / 10,000
        </div>
      </div>

      <div class="flex justify-between items-center">
        <span class="text-sm text-gray-500 dark:text-gray-400">작성자: {user.name || user.email}</span>
        <div class="flex gap-3">
          <a href="/community" class="px-6 py-3 rounded-lg glass text-gray-600 dark:text-gray-300 hover:text-white transition">취소</a>
          <button type="submit" id="submit-btn"
                  class="px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-medium transition">
            등록하기
          </button>
        </div>
      </div>

    </form>
  </main>

  <script>
    const form = document.getElementById('write-form') as HTMLFormElement;
    const contentEl = document.getElementById('content') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count') as HTMLSpanElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    contentEl.addEventListener('input', () => {
      charCount.textContent = String(contentEl.value.length);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = '등록 중...';

      const title = (document.getElementById('title') as HTMLInputElement).value.trim();
      const content = contentEl.value.trim();
      const category = (document.getElementById('category') as HTMLSelectElement).value;

      if (!title || !content) {
        errorMsg.textContent = '제목과 내용을 모두 입력하세요.';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = '등록하기';
        return;
      }

      try {
        const access_level = document.getElementById('access_level').value;
        const price = parseInt(document.getElementById('price').value) || 0;
        const preview_content = document.getElementById('preview_content')?.value?.trim() || '';

        const res = await fetch('/api/posts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, content, category, access_level, price, preview_content })
        });

        const data = await res.json();

        if (res.ok && data.success) {
          window.location.href = '/community/' + data.id;
        } else {
          errorMsg.textContent = data.error || '등록에 실패했습니다.';
          errorMsg.classList.remove('hidden');
        }
      } catch (err) {
        errorMsg.textContent = '네트워크 오류가 발생했습니다.';
        errorMsg.classList.remove('hidden');
      }

      submitBtn.disabled = false;
      submitBtn.textContent = '등록하기';
    });
  
    // access_level 변경 시 미리보기/가격 섹션 표시
    const accessSelect = document.getElementById('access_level');
    const previewSection = document.getElementById('preview-section');
    const priceInput = document.getElementById('price');
    accessSelect.addEventListener('change', () => {
      if (accessSelect.value !== 'free') {
        previewSection.classList.remove('hidden');
      } else {
        previewSection.classList.add('hidden');
        priceInput.value = '0';
      }
    });
  </script>

<script>
function googleTranslateElementInit(){
  new google.translate.TranslateElement({pageLanguage:'ko',includedLanguages:'en,ja,zh-CN,vi,th,es,fr',autoDisplay:false},'google_translate_element');
}
function doTranslate(lang){
  var s=document.querySelector('.goog-te-combo');
  if(s){s.value=lang;s.dispatchEvent(new Event('change'));}
  else{
    var url=encodeURIComponent(location.href);
    window.open('https://translate.google.com/translate?sl=ko&tl='+lang+'&u='+url,'_blank');
  }
}
setInterval(function(){
  var f=document.querySelector('.skiptranslate');if(f)f.style.display='none';
  document.body.style.top='0';
},300);
</script>
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
