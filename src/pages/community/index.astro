  <a href="javascript:void(0)" onclick="doTranslate('zh-CN')" class="flag-btn" title="中文" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/cn.png" alt="中文" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('ja')" class="flag-btn" title="日本語" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/jp.png" alt="日本語" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('vi')" class="flag-btn" title="Tiếng Việt" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/vn.png" alt="Tiếng Việt" style="width:100%;height:100%;object-fit:cover;"></a>
  <a href="javascript:void(0)" onclick="doTranslate('th')" class="flag-btn" title="ภาษาไทย" style="width:24px;height:18px;border-radius:3px;overflow:hidden;display:inline-block;opacity:0.7;cursor:pointer;border:none;background:none;"><img src="https://flagcdn.com/w80/th.png" alt="ภาษาไทย" style="width:100%;height:100%;object-fit:cover;"></a>
</div>
<div id="google_translate_element" style="display:none;"></div>

  <!-- 헤더 -->
  <header class="bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 backdrop-blur sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-white">🤖 aikorea24</a>
      <nav class="flex items-center gap-4 text-sm">
        <a href="/" class="text-gray-300 hover:text-white">홈</a>
        <a href="/community" class="text-white font-semibold">커뮤니티</a>
        {loggedIn ? (
          <a href="/community/write" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition">글쓰기</a>
        ) : (
          <a href="/auth/consent" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition">로그인</a>
        )}
      </nav>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-8">

    <!-- 타이틀 -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">커뮤니티</h1>
      <p class="text-gray-400">AI 관련 질문, 정보 공유, 프로젝트 자랑 등 자유롭게 이야기하세요.</p>
    </div>

    <!-- 카테고리 필터 -->
    <div class="flex flex-wrap gap-2 mb-6">
      <a href="/community"
         class:list={["px-4 py-2 rounded-full text-sm font-medium transition", !category ? 'bg-blue-600 text-white' : 'glass text-gray-300 hover:text-white']}>
        전체
      </a>
      {Object.entries(categoryMap).map(([key, label]) => (
        <a href={`/community?category=${key}`}
           class:list={["px-4 py-2 rounded-full text-sm font-medium transition", category === key ? 'bg-blue-600 text-white' : 'glass text-gray-300 hover:text-white']}>
          {label}
        </a>
      ))}
    </div>

    <!-- 게시글 목록 -->
    <div class="bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 backdrop-blur rounded-xl overflow-hidden">
      <!-- 테이블 헤더 -->
      <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider border-b border-gray-700">
        <div class="col-span-1 text-center">번호</div>
        <div class="col-span-2">카테고리</div>
        <div class="col-span-5">제목</div>
        <div class="col-span-2">작성자</div>
        <div class="col-span-1 text-center">조회</div>
        <div class="col-span-1 text-center">날짜</div>
      </div>

      {posts.length === 0 ? (
        <div class="px-6 py-16 text-center text-gray-500">
          <p class="text-lg mb-2">아직 게시글이 없습니다.</p>
          {loggedIn && <a href="/community/write" class="text-blue-400 hover:underline">첫 글을 작성해보세요!</a>}
        </div>
      ) : (
        posts.map((post: any) => (
          <a href={`/community/${post.id}`} class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 px-6 py-4 hover:bg-gray-50 dark:hover:bg-white/5 border-b border-gray-800 transition cursor-pointer">
            <div class="hidden md:block col-span-1 text-center text-gray-400 dark:text-gray-500 text-sm">{post.id}</div>
            <div class="col-span-2">
              <span class={`inline-block px-2 py-1 rounded text-xs font-medium ${categoryColors[post.category] || 'bg-gray-500/20 text-gray-300'}`}>
                {categoryMap[post.category] || post.category}
              </span>
            </div>
            <div class="col-span-5">
              <span class="text-white font-medium hover:text-blue-400 transition">{post.title}</span>
              {post.access_level === 'basic' && (
                <span class="ml-2 px-1.5 py-0.5 rounded text-xs bg-yellow-500/20 text-yellow-300">Basic</span>
              )}
              {post.access_level === 'premium' && (
                <span class="ml-2 px-1.5 py-0.5 rounded text-xs bg-red-500/20 text-red-300">Premium</span>
              )}
              {post.comment_count > 0 && (
                <span class="ml-2 text-blue-400 text-sm">[{post.comment_count}]</span>
              )}
            </div>
            <div class="col-span-2 text-gray-400 text-sm">{post.author_name}</div>
            <div class="hidden md:block col-span-1 text-center text-gray-400 dark:text-gray-500 text-sm">{post.views}</div>
            <div class="hidden md:block col-span-1 text-center text-gray-400 dark:text-gray-500 text-sm">{post.created_at?.slice(5, 10)}</div>
          </a>
        ))
      )}
    </div>

    <!-- 페이지네이션 -->
    {totalPages > 1 && (
      <div class="flex justify-center gap-2 mt-8">
        {page > 1 && (
          <a href={`/community?page=${page - 1}${category ? `&category=${category}` : ''}`}
             class="bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 backdrop-blur px-4 py-2 rounded-lg text-sm text-gray-300 hover:text-white transition">
            ← 이전
          </a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1)
          .filter(p => Math.abs(p - page) <= 2)
          .map(p => (
            <a href={`/community?page=${p}${category ? `&category=${category}` : ''}`}
               class:list={["px-4 py-2 rounded-lg text-sm transition", p === page ? 'bg-blue-600 text-white' : 'glass text-gray-300 hover:text-white']}>
              {p}
            </a>
          ))
        }
        {page < totalPages && (
          <a href={`/community?page=${page + 1}${category ? `&category=${category}` : ''}`}
             class="bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 backdrop-blur px-4 py-2 rounded-lg text-sm text-gray-300 hover:text-white transition">
            다음 →
          </a>
        )}
      </div>
    )}

    <!-- 총 게시글 수 -->
    <div class="text-center mt-4 text-gray-400 dark:text-gray-500 text-sm">
      총 {total}개의 게시글
    </div>

  </main>

<script is:inline>
function googleTranslateElementInit(){
  new google.translate.TranslateElement({pageLanguage:'ko',autoDisplay:false},'google_translate_element');
}
function doTranslate(lang){
  var s=document.querySelector('.goog-te-combo');
  if(s){s.value=lang;s.dispatchEvent(new Event('change'));return;}
  var i=setInterval(function(){
    var s2=document.querySelector('.goog-te-combo');
    if(s2){clearInterval(i);s2.value=lang;s2.dispatchEvent(new Event('change'));}
  },500);
  setTimeout(function(){clearInterval(i);},10000);
}
</script>
<script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<script is:inline>
function doTranslate(lang) {
  if (lang === 'ko') {
    if (window.location.hostname.includes('translate.goog')) {
      var orig = window.location.href.replace(/^https?:\/\/[^/]*translate\.goog/, 'https://aikorea24.kr');
      orig = orig.replace(/[?&]_x_tr_[^&]*/g, '');
      window.location.href = orig || 'https://aikorea24.kr';
    }
    return;
  }
  var url = 'https://translate.google.com/translate?sl=ko&tl=' + lang + '&u=' + encodeURIComponent(window.location.href);
  window.location.href = url;
}
</script>
</body>
</html>
