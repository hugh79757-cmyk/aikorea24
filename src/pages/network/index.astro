---
export const prerender = false;

interface FeedRow {
  domain: string;
  label: string;
  category: string;
}

interface CacheRow {
  domain: string;
  title: string;
  link: string;
  pub_date: string;
}

const categoryMeta: Record<string, { icon: string; color: string; gradient: string }> = {
  '스포츠': { icon: '⚽', color: 'border-green-500/30', gradient: 'from-green-500/20 to-emerald-500/20' },
  '여행': { icon: '✈️', color: 'border-sky-500/30', gradient: 'from-sky-500/20 to-blue-500/20' },
  '자동차': { icon: '🚗', color: 'border-red-500/30', gradient: 'from-red-500/20 to-rose-500/20' },
  '부동산': { icon: '🏠', color: 'border-amber-500/30', gradient: 'from-amber-500/20 to-yellow-500/20' },
  '생활정보': { icon: '💡', color: 'border-orange-500/30', gradient: 'from-orange-500/20 to-amber-500/20' },
  '금융·투자': { icon: '📈', color: 'border-indigo-500/30', gradient: 'from-indigo-500/20 to-blue-500/20' },
  '노인복지': { icon: '🤝', color: 'border-pink-500/30', gradient: 'from-pink-500/20 to-rose-500/20' },
  '맛집·레시피': { icon: '🍽️', color: 'border-yellow-500/30', gradient: 'from-yellow-500/20 to-orange-500/20' },
  '시사·이슈': { icon: '🔥', color: 'border-purple-500/30', gradient: 'from-purple-500/20 to-violet-500/20' },
};

const categoryOrder = ['스포츠', '여행', '자동차', '금융·투자', '부동산', '생활정보', '노인복지', '맛집·레시피', '시사·이슈'];

let categories: Record<string, { feeds: Record<string, { label: string; items: { title: string; link: string; pub_date: string }[] }> }> = {};
let lastUpdated = '';
let dbError = false;

try {
  const runtime = (Astro.locals as any).runtime;
  const db = runtime?.env?.DB;
  if (db) {
    const { results: feeds } = await db.prepare(
      'SELECT domain, label, category FROM network_feeds WHERE active = 1 ORDER BY category, label'
    ).all() as { results: FeedRow[] };

    const { results: cache } = await db.prepare(
      'SELECT domain, title, link, pub_date FROM network_cache ORDER BY pub_date DESC'
    ).all() as { results: CacheRow[] };

    const cacheMap: Record<string, CacheRow[]> = {};
    for (const row of cache) {
      if (!cacheMap[row.domain]) cacheMap[row.domain] = [];
      cacheMap[row.domain].push(row);
    }

    for (const feed of feeds) {
      if (!categories[feed.category]) {
        categories[feed.category] = { feeds: {} };
      }
      categories[feed.category].feeds[feed.domain] = {
        label: feed.label,
        items: (cacheMap[feed.domain] || []).slice(0, 3).map(c => ({
          title: c.title,
          link: c.link,
          pub_date: c.pub_date,
        })),
      };
    }

    const ts = await db.prepare(
      'SELECT fetched_at FROM network_cache ORDER BY fetched_at DESC LIMIT 1'
    ).first() as { fetched_at: string } | null;
    if (ts) lastUpdated = ts.fetched_at;
  }
} catch (e) {
  console.error('Network page DB error:', e);
  dbError = true;
}

import Layout from '../../layouts/Layout.astro';
---

<Layout title="콘텐츠 네트워크 | AI코리아24" description="AI코리아24가 큐레이션하는 84개 전문 블로그 네트워크. 스포츠, 여행, 금융, 자동차, 부동산 등 다양한 분야의 최신 콘텐츠를 한눈에.">
  <div class="bg-white dark:bg-[#0A0E1A] text-gray-900 dark:text-white min-h-screen relative overflow-hidden transition-colors">

    <!-- 앰비언트 배경 -->
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] bg-blue-600/20 rounded-full blur-[150px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-purple-600/15 rounded-full blur-[150px]"></div>
    </div>

    <section class="relative z-10 px-4 py-16 max-w-6xl mx-auto">
      <!-- 헤더 -->
      <div class="text-center mb-12">
        <p class="text-sm text-blue-500 dark:text-blue-400 font-medium mb-2">AI코리아24 콘텐츠 네트워크</p>
        <h1 class="text-3xl md:text-4xl font-bold mb-3">
          <span class="bg-gradient-to-r from-blue-500 via-purple-500 to-cyan-500 bg-clip-text text-transparent">84개 전문 블로그</span>
          <br class="md:hidden" /> 최신 콘텐츠
        </h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm max-w-xl mx-auto leading-relaxed">
          스포츠, 여행, 금융, 자동차, 부동산 등 9개 분야의 전문 블로그에서 발행하는 최신 콘텐츠를 한곳에서 확인하세요.
        </p>
        {lastUpdated && (
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-3">
            마지막 업데이트: {new Date(lastUpdated + 'Z').toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })}
          </p>
        )}
      </div>

      {dbError ? (
        <div class="text-center py-20">
          <p class="text-gray-400">데이터를 불러오는 중 문제가 발생했습니다. 잠시 후 다시 시도해주세요.</p>
        </div>
      ) : Object.keys(categories).length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-400">아직 수집된 콘텐츠가 없습니다. 곧 업데이트됩니다.</p>
        </div>
      ) : (
        <div class="space-y-10">
          {categoryOrder.filter(cat => categories[cat]).map(cat => {
            const meta = categoryMeta[cat] || { icon: '📌', color: 'border-gray-500/30', gradient: 'from-gray-500/20 to-slate-500/20' };
            const feedEntries = Object.entries(categories[cat].feeds);
            return (
              <div>
                <div class="flex items-center gap-2 mb-4">
                  <span class="text-2xl">{meta.icon}</span>
                  <h2 class="text-xl font-bold">{cat}</h2>
                  <span class="text-xs text-gray-400 dark:text-gray-500 ml-1">{feedEntries.length}개 블로그</span>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                  {feedEntries.map(([domain, data]) => (
                    <div class={`bg-gradient-to-br ${meta.gradient} backdrop-blur-sm border border-white/[0.06] ${meta.color} rounded-2xl p-5 transition-all duration-300 hover:scale-[1.02]`}>
                      <div class="flex items-center justify-between mb-3">
                        <a href={`https://${domain}`} target="_blank" rel="noopener"
                           class="text-sm font-bold text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
                          {data.label}
                        </a>
                        <span class="text-[10px] text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-white/[0.05] px-2 py-0.5 rounded-full">
                          {domain.split('.')[0]}
                        </span>
                      </div>
                      {data.items.length > 0 ? (
                        <ul class="space-y-2">
                          {data.items.map(item => (
                            <li>
                              <a href={item.link} target="_blank" rel="noopener"
                                 class="text-sm text-gray-600 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors line-clamp-2 leading-snug block">
                                · {item.title}
                              </a>
                            </li>
                          ))}
                        </ul>
                      ) : (
                        <p class="text-xs text-gray-400 dark:text-gray-500">콘텐츠 준비 중...</p>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      )}

      <!-- 하단 CTA -->
      <div class="mt-16 text-center">
        <div class="inline-block bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 rounded-2xl px-8 py-6">
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">AI코리아24가 운영하는 콘텐츠 네트워크입니다</p>
          <a href="/" class="text-blue-500 dark:text-blue-400 font-medium text-sm hover:underline">
            AI코리아24 메인으로 &rarr;
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
