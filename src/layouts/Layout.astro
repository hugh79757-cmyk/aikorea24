---
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  tags?: string[];
  category?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'AI 도구, 강좌, 지원사업, 뉴스를 한국어로 큐레이션합니다. AI, 누구나 쓸 수 있습니다.',
  image,
  type = 'website',
  publishedDate,
  modifiedDate,
  tags = [],
  category = '',
  noindex = false,
} = Astro.props;

let currentUser = null;
try {
  const session = Astro.cookies.get('session')?.value;
  if (session) currentUser = JSON.parse(atob(session));
} catch {}

const navItems = [
  { label: '홈', href: '/' },
  { label: '블로그', href: '/blog' },
  { label: 'AI 도구', href: '/tools' },
  { label: '용어사전', href: '/glossary' },
  { label: '타임라인', href: '/chronicle' },
  { label: '뉴스', href: '/news' },
  { label: '문의', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko" class="scroll-smooth dark">

  

<script is:inline>
function doTranslate(lang) {
  if (lang === 'ko') {
    if (window.location.hostname.includes('translate.goog')) {
      var orig = window.location.href.replace(/^https?:\/\/[^/]*translate\.goog/, 'https://aikorea24.kr');
      orig = orig.replace(/[?&]_x_tr_[^&]*/g, '');
      window.location.href = orig || 'https://aikorea24.kr';
    }
    return;
  }
  var url = 'https://translate.google.com/translate?sl=ko&tl=' + lang + '&u=' + encodeURIComponent(window.location.href);
  window.location.href = url;
}
</script>
</body>
</html>
