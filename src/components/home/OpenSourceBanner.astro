---
---

<section class="relative z-10 px-4 py-12">
  <div class="max-w-4xl mx-auto">
    <a href="https://github.com/aikorea24/aikeep24" target="_blank" rel="noopener"
       class="group block relative overflow-hidden rounded-2xl border border-purple-500/20 bg-gradient-to-r from-[#0d1117] via-[#161b22] to-[#0d1117] transition-all duration-500 hover:border-purple-500/40 hover:shadow-xl hover:shadow-purple-500/10">

      <!-- 배경 글로우 -->
      <div class="absolute top-0 right-0 w-72 h-72 bg-purple-600/20 rounded-full blur-[100px] group-hover:bg-purple-600/30 transition-all"></div>
      <div class="absolute bottom-0 left-0 w-56 h-56 bg-blue-600/15 rounded-full blur-[80px]"></div>

      <div class="relative flex flex-col md:flex-row items-center gap-6 p-6 md:p-8">

        <!-- 왼쪽: 아이콘 + 배지 -->
        <div class="flex-shrink-0 text-center">
          <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-purple-600 to-violet-700 flex items-center justify-center text-4xl shadow-lg shadow-purple-500/30 mb-3">
            🧠
          </div>
          <span class="inline-flex items-center gap-1 bg-green-500/20 text-green-400 text-xs font-bold px-3 py-1 rounded-full border border-green-500/30">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.58.93.65 1.16.13.42.53 1.2 2.06.86 0 .62.01 1.19.01 1.37 0 .21-.15.46-.55.38A8.013 8.013 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
            Open Source
          </span>
        </div>

        <!-- 중앙: 텍스트 -->
        <div class="flex-1 text-center md:text-left">
          <div class="flex items-center justify-center md:justify-start gap-3 mb-2">
            <h3 class="text-xl md:text-2xl font-bold text-white">AIKeep24</h3>
            <span class="text-xs bg-purple-500/20 text-purple-300 px-2 py-0.5 rounded-full border border-purple-500/30">AGPL-3.0</span>
          </div>
          <p class="text-gray-300 text-sm md:text-base mb-4 leading-relaxed">
            AI 대화를 자동 요약·태깅·저장하는 크롬 확장 프로그램.<br class="hidden md:block" />
            로컬 LLM으로 프라이버시를 지키면서 대화 맥락을 영구 보존합니다.
          </p>

          <!-- 기술 태그 -->
          <div class="flex flex-wrap justify-center md:justify-start gap-2 mb-4">
            <span class="text-xs bg-white/10 text-gray-300 px-2.5 py-1 rounded-lg">EXAONE 3.5 7.8B</span>
            <span class="text-xs bg-white/10 text-gray-300 px-2.5 py-1 rounded-lg">Cloudflare Vectorize</span>
            <span class="text-xs bg-white/10 text-gray-300 px-2.5 py-1 rounded-lg">Chrome Extension</span>
            <span class="text-xs bg-white/10 text-gray-300 px-2.5 py-1 rounded-lg">벡터 시맨틱 검색</span>
          </div>

          <!-- 통계 -->
          <div class="flex justify-center md:justify-start gap-6 text-center">
            <div>
              <div class="text-lg font-bold text-purple-400">120+</div>
              <div class="text-xs text-gray-500">세션</div>
            </div>
            <div>
              <div class="text-lg font-bold text-blue-400">793</div>
              <div class="text-xs text-gray-500">청크</div>
            </div>
            <div>
              <div class="text-lg font-bold text-cyan-400">12,525</div>
              <div class="text-xs text-gray-500">대화 턴</div>
            </div>
            <div>
              <div class="text-lg font-bold text-green-400">1,825</div>
              <div class="text-xs text-gray-500">코드 라인</div>
            </div>
          </div>
        </div>

        <!-- 오른쪽: GitHub 스타 + 화살표 -->
        <div class="flex-shrink-0 flex flex-col items-center gap-3">
          <img class="hidden md:block" src="https://img.shields.io/github/stars/aikorea24/aikeep24?style=social" alt="GitHub Stars" />
          <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-purple-500/30 group-hover:translate-x-1 transition-all">
            <svg class="w-5 h-5 text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </div>
        </div>

      </div>
    </a>
  </div>
</section>
